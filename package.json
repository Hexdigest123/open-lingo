		"brace-expansion": "^2.0.3",
		"cookie": "^0.7.0",
		"fast-xml-parser": "^5.5.7",
		"flatted": "^3.4.2",
		"minimatch": "^9.0.7",
		"picomatch": "^4.0.4",
		"postcss": "^8.5.10",
		"rollup": "^4.59.0",
